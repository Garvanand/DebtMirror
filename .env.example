# === DEBTMIRROR ===
DEBTMIRROR_K_ANONYMITY_OUTCOMES=10          # min similar cases before showing pattern
DEBTMIRROR_SETTLEMENT_DATA_EXPIRY_YEARS=2   # how long to use settlement data
DEBTMIRROR_REGULATORY_CORPUS_PATH=/data/rbi_corpus  # ChromaDB collection name

# No new API keys required.
# DebtMirror uses AgentOS core intelligence: Anthropic (existing), Groq (existing), OpenRouter (existing)
# RBI circular PDFs: downloaded during corpus ingestion, stored in MinIO (Day 05)
